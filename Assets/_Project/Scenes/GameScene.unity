  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::DialogueTrigger
  dialogueLines:
  - "\u041F\u0440\u0438\u0432\u0435\u0442! \u0421\u0442\u043E\u0439, \u043A\u0443\u0434\u0430
    \u0442\u044B? \u041D\u0443 \u0442\u044B \u0438 \u0441\u043E\u043D\u044F. \u041A\u0430\u043A
    \u0442\u0435\u0431\u044F \u0437\u043E\u0432\u0443\u0442? \u0422\u0435\u0431\u044F
    \u0434\u0430\u0436\u0435 \u0432\u0447\u0435\u0440\u0430\u0448\u043D\u0438\u0439
    \u0448\u0442\u043E\u0440\u043C \u043D\u0435 \u0440\u0430\u0437\u0431\u0443\u0434\u0438\u043B.
    \u0413\u043E\u0432\u043E\u0440\u044F\u0442, \u043C\u044B \u0443\u0436\u0435 \u043F\u0440\u0438\u043F\u043B\u044B\u043B\u0438
    \u0432 \u042D\u0439\u0440\u0445\u043E\u043B\u0434. \u041D\u0430\u0441 \u0432\u044B\u043F\u0443\u0441\u0442\u044F\u0442,
    \u044D\u0442\u043E \u0442\u043E\u0447\u043D\u043E!"
  - "\u0427\u0442\u043E \u043F\u043E\u043A\u0443\u043F\u0430\u0435\u0448\u044C?"
  hasChoices: 1
  choices:
  - choiceText: "\u041F\u043E\u043A\u0430\u0437\u044B\u0432\u0430\u0439"
    responseLines:
    - "\u0421\u043C\u043E\u0442\u0440\u0438"
  - choiceText: "\u042F \u043F\u043E\u0439\u0434\u0443"
    responseLines:
    - "\u0410\u0433\u0430"
  npcName: "\u0414\u044F\u0434\u044E\u0448\u043A\u0430 \u0411\u0440\u0430\u043D\u0442"
  npcFace: {fileID: -1728020032609300961, guid: 16b17c74ac57c414e9fe4f61aae8c55e, type: 3}
  interactPrompt: {fileID: 687000255}
