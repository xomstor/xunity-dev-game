--- !u!114 &905692837
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 905692833}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 3dd0a4362a863064b921f079668b96b9, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::DialogueTrigger
  dialogueLines:
  - "\u041D\u0438\u043A\u043E\u0433\u0434\u0430 \u043D\u0435 \u0445\u043E\u0434\u0438
    \u0432 \u043B\u0435\u0432\u0443\u044E \u0434\u0432\u0435\u0440\u044C.\r\n\u041F\u043E\u0442\u043E\u043C\u0443
    \u0447\u0442\u043E \u0441\u043F\u0440\u0430\u0432\u0430 \u0442\u043E\u0436\u0435
    \u043E\u043F\u0430\u0441\u043D\u043E."
  hasChoices: 1
  choices:
  - choiceText: "\u0422\u044B \u0434\u0432\u0435\u0440\u0438 \u0442\u0443\u0442 \u0432\u0438\u0434\u0438\u0448\u044C?"
    responseLines:
    - "\u041F\u043E\u0447\u0435\u043C\u0443? \u0421\u043B\u0443\u0448 \u0442\u0443\u0442
      \u0442\u0430\u043A\u043E\u0435 \u0434\u0435\u043B\u043E...."
    - "\u042F \u0441\u0432\u043E\u044E \u0448\u0432\u0430\u0431\u0440\u0443 \u043F\u043E\u0442\u0435\u0440\u044F\u043B.
      \u041F\u0440\u0438\u043D\u0435\u0441\u0451\u0448\u044C \u043C\u043D\u0435 \u043C\u043E\u044E
      \u043C\u0435\u0442\u043B\u0443? \u041E\u043D\u0430 \u0431\u044B\u043B\u0430
      \u0443 \u0442\u0438\u0433\u0440\u0430, \u044F \u0442\u043E\u0447\u043D\u043E
      \u0432\u0438\u0434\u0435\u043B. \u0418\u043D\u0442\u0435\u0440\u0435\u0441\u043D\u043E,
      \u0432 \u043A\u0430\u043A\u043E\u0439 \u043A\u0430\u0440\u043C\u0430\u043D
      \u043E\u043D \u0435\u0451 \u043F\u043E\u043B\u043E\u0436\u0438\u043B..."
    subChoices: []
    startsQuest: 1
  - choiceText: "\u0422\u044B \u0441\u0442\u0440\u0430\u043D\u043D\u044B\u0439."
    responseLines:
    - "\u042F \u0442\u043E\u0436\u0435 \u0442\u0430\u043A \u0434\u0443\u043C\u0430\u044E.
      \u041D\u043E \u0434\u0432\u0435\u0440\u0438 \u0438 \u043E\u043A\u043D\u0430
      \u0441\u043E \u043C\u043D\u043E\u0439 \u0441\u043E\u0433\u043B\u0430\u0441\u043D\u044B."
    subChoices: []
    startsQuest: 0
  - choiceText: "\u042F \u0443\u0436\u0435 \u0441\u043B\u044B\u0448\u0430\u043B \u044D\u0442\u043E"
    responseLines:
    - "\u042F \u043F\u043E\u043C\u043D\u044E, \u043A\u0430\u043A \u0442\u044B \u0443\u0436\u0435
      \u0441\u043F\u0440\u0430\u0448\u0438\u0432\u0430\u043B. \u042F \u0442\u043E\u0436\u0435
      \u0432\u043F\u0435\u0440\u0432\u044B\u0435 \u0442\u0435\u0431\u044F \u0432\u0438\u0436\u0443."
    subChoices: []
    startsQuest: 0
  npcName: "\u041A\u0430\u0447\u043A\u043E\u0432\u044B\u0439 \u0423\u0431\u043E\u0440\u0449\u0438\u043A
    \u0424\u043B\u0438\u043D\u043D"
  npcFace: {fileID: 6409705411929556632, guid: c3b33d6a620d5f44581dfee021867b0d, type: 3}
  npcFaceFrames: []
  npcFaceAfterQuest: {fileID: -839195332947501829, guid: b678c66fa2aa3254b96ddee7b246ad64, type: 3}
  npcFaceFramesAfterQuest: []
  animatorAfterQuest: {fileID: 9100000, guid: fd0cd389242acc34fa10fbb91864134c, type: 2}
  spriteAfterQuest: {fileID: 0}
  interactPrompt: {fileID: 1252784088}
  shopNPC: {fileID: 0}
  openShopOnChoice0: 1
  requiredItem: {fileID: 11400000, guid: 9b967820dce14cb5ad23c1a9b2205ca1, type: 2}
  requiredAmount: 1
  rewardGold: 120
  rewardExperience: 150
  questCompleteLines:
  - "\u0412\u043E\u0442 \u0442\u0432\u043E\u044F \u043C\u0435\u0442\u043B\u0430!
    \u0422\u0435\u043F\u0435\u0440\u044C \u044F \u043C\u043E\u0433\u0443 \u0443\u0431\u0438\u0440\u0430\u0442\u044C
    \u044D\u0442\u043E\u0442 \u0431\u0430\u0440\u0434\u0430\u043A! \u0414\u0432\u0435\u0440\u044C
    \u0443\u0431\u0435\u0436\u0430\u043B\u0430 \u0437\u0430\u043A\u0440\u044B\u0442\u0430\u044F!"
  questProgressLines:
  - "\u041F\u0440\u0438\u043D\u0435\u0441\u0438 \u043C\u043D\u0435 \u043C\u0435\u0442\u043B\u0443.
    \u0413\u043E\u0432\u043E\u0440\u044F\u0442, \u0442\u0438\u0433\u0440\u044B \u043D\u043E\u0441\u044F\u0442
    \u0438\u0445 \u0441 \u0441\u043E\u0431\u043E\u0439. \u0418\u043D\u0442\u0435\u0440\u0435\u0441\u043D\u043E,
    \u0433\u0434\u0435 \u0443 \u043D\u0438\u0445 \u0442\u0430\u043A\u043E\u0439 \u043A\u0430\u0440\u043C\u0430\u043D?"
  questAlreadyDoneLines:
  - "\u0421\u043F\u0430\u0441\u0438\u0431\u043E \u0437\u0430 \u043C\u0435\u0442\u043B\u0443.
    \u0411\u0430\u0440\u0434\u0430\u043A \u0443\u0436\u0435 \u0443\u0431\u0440\u0430\u043D!"
  references:
    version: 2
    RefIds: []
