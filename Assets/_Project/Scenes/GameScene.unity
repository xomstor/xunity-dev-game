--- !u!114 &1036889370
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1036889362}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 3dd0a4362a863064b921f079668b96b9, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::DialogueTrigger
  dialogueLines:
  - "\u041F\u0440\u0438\u0432\u0435\u0442, \u043F\u0443\u0442\u043D\u0438\u043A!
    \u041D\u0443\u0436\u043D\u043E \u043F\u0440\u0438\u043D\u044F\u0442\u044C \u043D\u043E\u0432\u044B\u0439
    \u043C\u0438\u0440! "
  - "\u042F \u041C\u0435\u0433\u0443... \u043A\u0445-\u041A\u0425\u0415..."
  - "\u042F \u041B\u0438\u0440\u0430 \u0412\u0435\u0439\u043D, \u0418\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u0435\u043B\u044C\u043D\u0438\u0446\u0430
    \u0421\u0435\u0440\u043E\u0433\u043E \u0420\u0430\u0441\u043A\u043E\u043B\u0430,
    \u0432\u0435\u043B\u0438\u043A\u0438\u0439 \u043C\u0430\u0433 \u0432\u0437\u0440\u044B\u0432\u043E\u0432."
  - "\u041F\u0440\u043E\u0448\u043B\u044B\u0439 \u043C\u0438\u0440 \u043D\u0435\u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E
    \u0432\u0435\u0440\u043D\u0443\u0442\u044C \u043F\u043E\u043B\u043D\u043E\u0441\u0442\u044C\u044E.
    \u041F\u0440\u0438\u043D\u0435\u0441\u0438 \u043C\u043D\u0435 \u043A\u0440\u0430\u0441\u043D\u044B\u0439
    \u043A\u0430\u043C\u0435\u043D\u044C, \u0438 \u044F \u0434\u0430\u043C \u043D\u0430\u0433\u0440\u0430\u0434\u0443."
  hasChoices: 0
  choices: []
  npcName: "\u041B\u0438\u0440\u0430 \u0412\u0435\u0439\u043D"
  npcFace: {fileID: 2150897734078096205, guid: 5de54a1c41fda7045a6095ccf226aca4, type: 3}
  npcFaceFrames: []
  npcFaceAfterQuest: {fileID: 0}
  npcFaceFramesAfterQuest: []
  animatorAfterQuest: {fileID: 0}
  spriteAfterQuest: {fileID: 0}
  interactPrompt: {fileID: 483771129}
  shopNPC: {fileID: 0}
  openShopOnChoice0: 0
  requiredItem: {fileID: 11400000, guid: 0307124f233e450290da99f7d53ca176, type: 2}
  requiredAmount: 1
  rewardGold: 65
  rewardExperience: 200
  questCompleteLines:
  - "\u0422\u044B \u043D\u0430\u0448\u0451\u043B \u043C\u043E\u0435\u0433\u043E \u0433\u043E\u041F\u043E\u043D\u0438\u043A\u0430!
    \u042F \u0435\u0433\u043E \u043A\u0440\u0443\u0442\u0438\u043B\u0430 \u0434\u043E
    \u0433\u0430\u0440\u0430\u043D\u0442\u0430!"
  - "\u041E\u0442\u043B\u0438\u0447\u043D\u043E! \u042D\u0442\u043E\u0442 \u043A\u0440\u0430\u0441\u043D\u044B\u0439
    \u043A\u0430\u043C\u0435\u043D\u044C \u043F\u043E\u043C\u043E\u0436\u0435\u0442
    \u043C\u043D\u0435 \u0432 \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u044F\u0445."
  - "\u041F\u043E\u0437\u0434\u0440\u0430\u0432\u043B\u044F\u044E, \u0442\u044B \u0441\u043F\u0430\u0441
    \u043C\u0438\u0440! \u041D\u0430\u0432\u0435\u0440\u043D\u043E\u0435."
  questProgressLines:
  - "\u041F\u0440\u0438\u043D\u0435\u0441\u0438 \u043C\u043D\u0435 \u043A\u0440\u0430\u0441\u043D\u044B\u0439
    \u043A\u0430\u043C\u0435\u043D\u044C. \u041E\u043D \u0433\u0434\u0435-\u0442\u043E
    \u043D\u0430 \u043A\u0430\u0440\u0442\u0435."
  questAlreadyDoneLines:
  - "\u0421\u043F\u0430\u0441\u0438\u0431\u043E \u0437\u0430 \u043A\u0430\u043C\u0435\u043D\u044C!
    \u041E\u043D \u043E\u0447\u0435\u043D\u044C \u043F\u043E\u043C\u043E\u0433, \u0431\u044B\u043B\u043E
    \u0432\u043A\u0443\u0441\u043D\u043E!"
  references:
    version: 2
    RefIds: []
