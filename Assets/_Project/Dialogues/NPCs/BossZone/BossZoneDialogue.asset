  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 049cc01777f548988a8d62b4974c0502, type: 3}
  m_Name: BossZoneDialogue
  m_EditorClassIdentifier: Assembly-CSharp::BossDialogueData
  npcName: "\u0425\u0440\u0430\u043D\u0438\u0442\u0435\u043B\u044C \u0420\u0430\u0441\u043A\u043E\u043B\u0430"
  npcFace: {fileID: 0}
  npcFaceFrames: []
  dialogueLines:
  - "\u0422\u044B \u0441\u043B\u044B\u0448\u0438\u0448\u044C, \u043A\u0430\u043A \u043F\u0435\u043F\u0435\u043B \u0448\u0435\u043F\u0447\u0435\u0442?"
  - "\u042F \u2014 \u0442\u043E\u0442, \u043A\u0442\u043E \u043E\u0441\u0442\u0430\u043B\u0441\u044F \u0443 \u043F\u043E\u0440\u043E\u0433\u0430. \u0425\u0440\u0430\u043D\u0438\u0442\u0435\u043B\u044C, \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u043D\u0435 \u0437\u0430\u0449\u0438\u0449\u0430\u0435\u0442, \u0430 \u0441\u0432\u0438\u0434\u0435\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0443\u0435\u0442."
  - "\u0421\u0435\u0440\u044B\u0439 \u0420\u0430\u0441\u043A\u043E\u043B \u043D\u0435 \u0443\u043D\u0438\u0447\u0442\u043E\u0436\u0438\u043B \u043C\u0438\u0440. \u041E\u043D \u0440\u0430\u0437\u043C\u043D\u043E\u0436\u0438\u043B \u0435\u0433\u043E. \u0422\u0435\u043F\u0435\u0440\u044C \u043A\u0430\u0436\u0434\u044B\u0439 \u0448\u0430\u0433 \u2014 \u0432\u044B\u0431\u043E\u0440 \u043C\u0435\u0436\u0434\u0443 \u0432\u0435\u0440\u0441\u0438\u044F\u043C\u0438."
  - "\u041A\u0442\u043E-\u0442\u043E \u0433\u043E\u0432\u043E\u0440\u0438\u0442, \u0447\u0442\u043E \u0420\u0430\u0441\u043A\u043E\u043B \u2014 \u044D\u0442\u043E \u043D\u0430\u043A\u0430\u0437\u0430\u043D\u0438\u0435. \u041A\u0442\u043E-\u0442\u043E \u2014 \u0447\u0442\u043E \u044D\u043A\u0441\u043F\u0435\u0440\u0438\u043C\u0435\u043D\u0442. \u041A\u0442\u043E-\u0442\u043E \u2014 \u0447\u0442\u043E \u0441\u043F\u0430\u0441\u0435\u043D\u0438\u0435."
  - "\u0412\u0441\u0435 \u044D\u0442\u0438 \u043F\u0440\u0430\u0432\u0434\u044B \u0443\u043A\u043B\u0430\u0434\u044B\u0432\u0430\u044E\u0442\u0441\u044F \u0432 \u043E\u0434\u043D\u043E\u043C \u043C\u0435\u0441\u0442\u0435 \u2014 \u0432 \u0421\u0435\u0440\u0434\u0446\u0435 \u041F\u0435\u043F\u043B\u0430."
  - "\u041E\u043D\u043E \u043D\u0435 \u043C\u043E\u0436\u0435\u0442 \u0431\u044B\u0442\u044C \u043E\u0431\u044A\u044F\u0441\u043D\u0435\u043D\u043E. \u041E\u043D\u043E \u043E\u0434\u043D\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E \u0438 \u043C\u0430\u0448\u0438\u043D\u0430, \u0438 \u0445\u0440\u0430\u043C, \u0438 \u0434\u0435\u0440\u0435\u0432\u043E, \u0438 \u0440\u0430\u043D\u0430, \u0438 \u0436\u0438\u0432\u043E\u0439 \u043E\u0441\u043A\u043E\u043B\u043E\u043A."
  - "\u0422\u044B \u0438\u0434\u0451\u0448\u044C \u043A \u043D\u0435\u043C\u0443, \u041A\u0430\u044D\u043B\u044C. \u0418\u043B\u0438 \u043A \u0442\u043E\u043C\u0443, \u0447\u0442\u043E \u043E\u0441\u0442\u0430\u043D\u0435\u0442\u0441\u044F \u043E\u0442 \u0442\u0435\u0431\u044F."
  - "\u042F \u0432\u0438\u0434\u0435\u043B, \u043A\u0430\u043A \u0442\u044B \u043F\u0440\u0438\u0445\u043E\u0434\u0438\u043B. \u041D\u0435\u0442, \u043D\u0435 \u0432 \u044D\u0442\u043E\u0442 \u0440\u0430\u0437. \u0412 \u0434\u0440\u0443\u0433\u043E\u0439 \u0432\u0435\u0440\u0441\u0438\u0438."
  - "\u0422\u044B \u043D\u0435 \u043F\u043E\u043C\u043D\u0438\u0448\u044C, \u043F\u043E\u0442\u043E\u043C\u0443 \u0447\u0442\u043E \u043F\u0430\u043C\u044F\u0442\u044C \u043D\u0435 \u0432\u044B\u0434\u0435\u0440\u0436\u0438\u0432\u0430\u0435\u0442. \u0422\u043E\u043B\u044C\u043A\u043E \u0436\u0435\u043B\u0430\u043D\u0438\u0435 \u0438\u0434\u0442\u0438 \u2014 \u043E\u0441\u0442\u0430\u0451\u0442\u0441\u044F."
  - "\u0414\u0440\u0430\u043A \u0432\u0451\u0437 \u0442\u0435\u0431\u044F \u0447\u0435\u0440\u0435\u0437 \u043F\u0435\u043F\u0435\u043B. \u041B\u0438\u0440\u0430 \u043C\u043E\u043B\u0447\u0430\u043B\u0430. \u0412\u0430\u0440\u043A\u0441 \u0441\u0447\u0438\u0442\u0430\u043B \u0442\u0435\u0431\u044F \u043E\u0448\u0438\u0431\u043A\u043E\u0439. \u042D\u043B\u043B\u0438\u0440 \u043D\u0430\u0437\u044B\u0432\u0430\u043B\u0430 \u043D\u0435\u0437\u0430\u0432\u0435\u0440\u0448\u0451\u043D\u043D\u044B\u043C \u043F\u0440\u043E\u0446\u0435\u0441\u0441\u043E\u043C."
  - "\u041A\u0430\u0436\u0434\u044B\u0439 \u0438\u0437 \u043D\u0438\u0445 \u043F\u0440\u0430\u0432. \u0418 \u043A\u0430\u0436\u0434\u044B\u0439 \u043B\u0436\u0451\u0442. \u041F\u043E\u0442\u043E\u043C\u0443 \u0447\u0442\u043E \u043F\u0440\u0430\u0432\u0434\u0430 \u2014 \u044D\u0442\u043E \u043D\u0435 \u043F\u0430\u043C\u044F\u0442\u044C. \u041F\u0440\u0430\u0432\u0434\u0430 \u2014 \u0442\u043E, \u0447\u0442\u043E \u0442\u044B \u0441\u0434\u0435\u043B\u0430\u0435\u0448\u044C \u0434\u0430\u043B\u044C\u0448\u0435."
  - "\u041C\u0438\u0440\u0430\u044D\u043B\u044C \u0445\u043E\u0442\u0435\u043B\u0430 \u0432\u0435\u0440\u043D\u0443\u0442\u044C \u0441\u0442\u0430\u0440\u044B\u0439 \u043C\u0438\u0440. \u0421\u0430\u0439\u043B\u0430\u0441 \u043F\u0440\u043E\u0434\u0430\u0432\u0430\u043B \u0432\u0435\u0440\u0441\u0438\u0438. \u0422\u044B \u0436\u0435, \u043C\u043E\u0436\u0435\u0442, \u043F\u0440\u043E\u0441\u0442\u043E \u0438\u0434\u0451\u0448\u044C."
  - "\u041D\u043E \u0432\u043F\u0435\u0440\u0435\u0434\u0438 \u2014 \u043D\u0435 \u0431\u043E\u0441\u0441. \u0412\u043F\u0435\u0440\u0435\u0434\u0438 \u2014 \u0432\u044B\u0440\u0430\u0436\u0435\u043D\u0438\u0435 \u0421\u0430\u043C\u043E\u0433\u043E \u0420\u0430\u0441\u043A\u043E\u043B\u0430. \u0422\u043E, \u0447\u0442\u043E \u043F\u0438\u0442\u0430\u0435\u0442\u0441\u044F \u043F\u043E\u043F\u044B\u0442\u043A\u0430\u043C\u0438 \u0440\u0435\u0448\u0438\u0442\u044C, \u043A\u0430\u043A\u0430\u044F \u0438\u0437 \u0432\u0435\u0440\u0441\u0438\u0439 \u0440\u0435\u0430\u043B\u044C\u043D\u043E\u0441\u0442\u0438 \u0434\u043E\u0441\u0442\u043E\u0439\u043D\u0430 \u0436\u0438\u0442\u044C."
  - "\u0415\u0441\u043B\u0438 \u043F\u043E\u0431\u0435\u0434\u0438\u0448\u044C \u2014 \u043D\u0438\u0447\u0435\u0433\u043E \u043D\u0435 \u0437\u0430\u043A\u043E\u043D\u0447\u0438\u0442\u0441\u044F. \u0422\u044B \u043B\u0438\u0448\u044C \u0437\u0430\u043A\u0440\u0435\u043F\u0438\u0448\u044C \u043E\u0434\u043D\u0443 \u0432\u0435\u0440\u0441\u0438\u044E."
  - "\u0415\u0441\u043B\u0438 \u043F\u0440\u043E\u0438\u0433\u0440\u0430\u0435\u0448\u044C \u2014 \u0434\u0440\u0443\u0433\u0430\u044F \u0432\u0435\u0440\u0441\u0438\u044F \u0437\u0430\u043A\u0440\u0435\u043F\u0438\u0442\u0441\u044F \u0437\u0430 \u0442\u0435\u0431\u044F."
  - "\u0414\u0432\u0435\u0440\u044C \u043E\u0442\u043A\u0440\u044B\u0442\u0430. \u041D\u043E \u043D\u0435 \u043C\u043D\u043E\u0439. \u041E\u043D\u0430 \u043E\u0442\u043A\u0440\u044B\u0442\u0430 \u0442\u0432\u043E\u0438\u043C \u043F\u0440\u0438\u0441\u0443\u0442\u0441\u0442\u0432\u043E\u043C."
  - "\u0412\u043E\u0439\u0434\u0451\u0448\u044C \u2014 \u0438 \u0421\u0438\u0441\u0442\u0435\u043C\u0430 \u0443\u0432\u0438\u0434\u0438\u0442 \u0442\u0435\u0431\u044F. \u0418\u043B\u0438, \u043C\u043E\u0436\u0435\u0442 \u0431\u044B\u0442\u044C, \u0443\u0432\u0438\u0434\u0438\u0442 \u0441\u0435\u0431\u044F \u0432 \u0442\u0435\u0431\u0435."
  - "\u042F \u043D\u0435 \u0441\u043A\u0430\u0436\u0443, \u0447\u0442\u043E \u0442\u0430\u043C \u0436\u0434\u0451\u0442. \u042F \u043D\u0435 \u0437\u043D\u0430\u044E. \u042F \u2014 \u0445\u0440\u0430\u043D\u0438\u0442\u0435\u043B\u044C, \u0430 \u043D\u0435 \u043F\u0440\u043E\u0440\u043E\u043A."
  - "\u0418\u0434\u0438. \u041F\u0435\u043F\u0435\u043B \u043F\u043E\u043C\u043D\u0438\u0442 \u0442\u043E\u043B\u044C\u043A\u043E \u0442\u0435\u0445, \u043A\u0442\u043E \u0432\u044B\u0431\u0440\u0430\u043B \u0438\u0434\u0442\u0438."
  bossSceneName: BossGameScene
  bossSpawnPointName: Boss1SpawnPoint
  playOnlyOnce: 1
