  requiredAmount: 6
  rewardGold: 50
  rewardExperience: 100
  npcName: "\u041C\u0435\u0440\u0447\u0430\u043D\u0442"
  npcFace: {fileID: 0}
  introLines:
  - "\u041F\u0440\u0438\u0432\u0435\u0442! \u042F \u0438\u0449\u0443 \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u043D\u044B\u0435
    \u043F\u0440\u0435\u0434\u043C\u0435\u0442\u044B."
  - "\u041F\u0440\u0438\u043D\u0435\u0441\u0438 \u043C\u043D\u0435 \u0438\u0445,
    \u0438 \u044F \u043D\u0430\u0433\u0440\u0430\u0436\u0443 \u0442\u0435\u0431\u044F!"
  progressLines:
  - "\u0422\u044B \u0435\u0449\u0435 \u043D\u0435 \u0441\u043E\u0431\u0440\u0430\u043B
    \u0432\u0441\u0435, \u0447\u0442\u043E \u043D\u0443\u0436\u043D\u043E."
  - "\u0412\u0435\u0440\u043D\u0438\u0441\u044C, \u043A\u043E\u0433\u0434\u0430 \u0431\u0443\u0434\u0435\u0442
    \u0434\u043E\u0441\u0442\u0430\u0442\u043E\u0447\u043D\u043E."
  completeLines:
  - "\u041E\u0442\u043B\u0438\u0447\u043D\u043E! \u0422\u044B \u0441\u043E\u0431\u0440\u0430\u043B
    \u0432\u0441\u0435, \u0447\u0442\u043E \u043D\u0443\u0436\u043D\u043E!"
  - "\u0412\u043E\u0442 \u0442\u0432\u043E\u044F \u043D\u0430\u0433\u0440\u0430\u0434\u0430:"
  alreadyDoneLines:
  - "\u0421\u043F\u0430\u0441\u0438\u0431\u043E \u0437\u0430 \u043F\u043E\u043C\u043E\u0449\u044C!
    \u0412\u043E\u0437\u0432\u0440\u0430\u0449\u0430\u0439\u0441\u044F \u043F\u043E\u0437\u0436\u0435."
